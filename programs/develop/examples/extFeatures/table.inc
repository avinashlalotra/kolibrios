;
 ; Feature set definitions
 ;

EXT4_FEATURE_COMPAT_DIR_PREALLOC	equ 0x0001
EXT4_FEATURE_COMPAT_IMAGIC_INODES	equ 0x0002
EXT4_FEATURE_COMPAT_HAS_JOURNAL		equ 0x0004
EXT4_FEATURE_COMPAT_EXT_ATTR		equ 0x0008
EXT4_FEATURE_COMPAT_RESIZE_INODE	equ 0x0010
EXT4_FEATURE_COMPAT_DIR_INDEX		equ 0x0020
EXT4_FEATURE_COMPAT_SPARSE_SUPER2	equ 0x0200
;
 ; The reason why "FAST_COMMIT" is a compat feature is that, FS becomes
 ; incompatible only if fast commit blocks are present in the FS. Since we
 ; clear the journal (and thus the fast commit blocks), we don't mark FS as
 ; incompatible. We also have a JBD2 incompat feature, which gets set when
 ; there are fast commit blocks present in the journal.
 ;
EXT4_FEATURE_COMPAT_FAST_COMMIT		equ 0x0400
EXT4_FEATURE_COMPAT_STABLE_INODES	equ 0x0800
EXT4_FEATURE_COMPAT_ORPHAN_FILE		equ 0x1000	; Orphan file exists ;

EXT4_FEATURE_RO_COMPAT_SPARSE_SUPER	equ 0x0001
EXT4_FEATURE_RO_COMPAT_LARGE_FILE	equ 0x0002
EXT4_FEATURE_RO_COMPAT_BTREE_DIR	equ 0x0004
EXT4_FEATURE_RO_COMPAT_HUGE_FILE        equ 0x0008
EXT4_FEATURE_RO_COMPAT_GDT_CSUM		equ 0x0010
EXT4_FEATURE_RO_COMPAT_DIR_NLINK	equ 0x0020
EXT4_FEATURE_RO_COMPAT_EXTRA_ISIZE	equ 0x0040
EXT4_FEATURE_RO_COMPAT_QUOTA		equ 0x0100
EXT4_FEATURE_RO_COMPAT_BIGALLOC		equ 0x0200
;
 ; METADATA_CSUM also enables group descriptor checksums (GDT_CSUM).  When
 ; METADATA_CSUM is set, group descriptor checksums use the same algorithm as
 ; all other data structures' checksums.  However, the METADATA_CSUM and
 ; GDT_CSUM bits are mutually exclusive.
 ;
EXT4_FEATURE_RO_COMPAT_METADATA_CSUM	equ 0x0400
EXT4_FEATURE_RO_COMPAT_READONLY		equ 0x1000
EXT4_FEATURE_RO_COMPAT_PROJECT		equ 0x2000
EXT4_FEATURE_RO_COMPAT_VERITY		equ 0x8000
EXT4_FEATURE_RO_COMPAT_ORPHAN_PRESENT	equ 0x10000 ; Orphan file may be non-empty ;

EXT4_FEATURE_INCOMPAT_COMPRESSION	equ 0x0001
EXT4_FEATURE_INCOMPAT_FILETYPE		equ 0x0002
EXT4_FEATURE_INCOMPAT_RECOVER		equ 0x0004 ; Needs recovery ;
EXT4_FEATURE_INCOMPAT_JOURNAL_DEV	equ 0x0008 ; Journal device ;
EXT4_FEATURE_INCOMPAT_META_BG		equ 0x0010
EXT4_FEATURE_INCOMPAT_EXTENTS		equ 0x0040 ; extents support ;
EXT4_FEATURE_INCOMPAT_64BIT		equ 0x0080
EXT4_FEATURE_INCOMPAT_MMP               equ 0x0100
EXT4_FEATURE_INCOMPAT_FLEX_BG		equ 0x0200
EXT4_FEATURE_INCOMPAT_EA_INODE		equ 0x0400 ; EA in inode ;
EXT4_FEATURE_INCOMPAT_DIRDATA		equ 0x1000 ; data in dirent ;
EXT4_FEATURE_INCOMPAT_CSUM_SEED		equ 0x2000
EXT4_FEATURE_INCOMPAT_LARGEDIR		equ 0x4000 ; >2GB or 3-lvl htree ;
EXT4_FEATURE_INCOMPAT_INLINE_DATA	equ 0x8000 ; data in inode ;
EXT4_FEATURE_INCOMPAT_ENCRYPT		equ 0x10000
EXT4_FEATURE_INCOMPAT_CASEFOLD		equ 0x20000


